# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5480/alizia?sslmode=disable
JWT_SECRET=your-jwt-secret-here
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Optional
PORT=8080
ENV=local
AZURE_OPENAI_MODEL=gpt-5-mini
BUGSNAG_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Test tokens — generate with: go run scripts/gen_token.go (or use POST /api/v1/auth/login)
# Signed with JWT_SECRET above, org=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11
# Do NOT commit real tokens here. These placeholders remind you to generate your own.
TEST_TOKEN_ADMIN=<generate-your-own>
TEST_TOKEN_COORDINATOR=<generate-your-own>
TEST_TOKEN_TEACHER=<generate-your-own>
