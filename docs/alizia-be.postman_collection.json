{
	"info": {
		"name": "Alizia BE",
		"description": "Alizia Backend API Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					}
				}
			]
		},
		{
			"name": "Onboarding",
			"item": [
				{
					"name": "Get Onboarding Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/users/me/onboarding-status",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users", "me", "onboarding-status"]
						},
						"description": "Returns whether the authenticated user has completed onboarding and when."
					}
				},
				{
					"name": "Complete Onboarding",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/users/me/onboarding/complete",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users", "me", "onboarding", "complete"]
						},
						"description": "Marks the authenticated user's onboarding as completed. Idempotent."
					}
				},
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/users/me/profile",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users", "me", "profile"]
						},
						"description": "Returns the authenticated user's profile data (dynamic JSONB fields)."
					}
				},
				{
					"name": "Save Profile",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"disciplines\": [\"Matematicas\", \"Fisica\"],\n  \"experience_years\": 5\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/users/me/profile",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users", "me", "profile"]
						},
						"description": "Saves or updates the authenticated user's profile data. Validated against org config profile_fields."
					}
				},
				{
					"name": "Get Tour Steps",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/users/me/onboarding/tour-steps",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users", "me", "onboarding", "tour-steps"]
						},
						"description": "Returns tour steps filtered by user roles and org feature flags. Defaults to welcome + explore if no config."
					}
				},
				{
					"name": "Get Onboarding Config",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/onboarding-config",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "onboarding-config"]
						},
						"description": "Returns the organization's onboarding configuration (profile fields, tour steps, skip_allowed)."
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Assign Coordinator to Area",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"<user_uuid>\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/areas/:id/coordinators",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "areas", ":id", "coordinators"],
							"variable": [
								{
									"key": "id",
									"value": "",
									"description": "Area UUID"
								}
							]
						},
						"description": "Assigns a coordinator to an area. Admin only."
					}
				},
				{
					"name": "Remove Coordinator from Area",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/areas/:id/coordinators/:user_id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "areas", ":id", "coordinators", ":user_id"],
							"variable": [
								{
									"key": "id",
									"value": "",
									"description": "Area UUID"
								},
								{
									"key": "user_id",
									"value": "",
									"description": "User UUID to remove as coordinator"
								}
							]
						},
						"description": "Removes a coordinator from an area. Admin only."
					}
				}
			]
		}
	]
}
